<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" prefHeight="775.0" prefWidth="500.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.elliottandcoachgeorge.javafxtest.BabyController">

    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding><Insets bottom="20" left="20" right="20" top="40"/></padding>
            <GridPane alignment="CENTER" hgap="8" vgap="8">
                <!-- Row 0 -->
                <Label fx:id="r0c0" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="r0c1" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label fx:id="r0c2" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <!-- Row 1 -->
                <Label fx:id="r1c0" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="r1c1" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label fx:id="r1c2" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <!-- Row 2 -->
                <Label fx:id="r2c0" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="r2c1" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label fx:id="r2c2" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                <!-- Row 3 -->
                <Label fx:id="r3c0" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label fx:id="r3c1" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label fx:id="r3c2" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                <!-- Row 4 -->
                <Label fx:id="r4c0" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <Label fx:id="r4c1" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label fx:id="r4c2" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                <!-- Row 5 -->
                <Label fx:id="r5c0" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <Label fx:id="r5c1" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label fx:id="r5c2" alignment="CENTER" prefHeight="70" prefWidth="70" style="-fx-font-size:28; -fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
            </GridPane>
        </VBox>
    </center>

    <right>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <ImageView fx:id="logoImage" fitWidth="180" preserveRatio="true">
                <image><Image url="@../../../Images/Logo.png"/></image>
            </ImageView>
            <Button fx:id="backButton" onAction="#handleBack" prefHeight="65" prefWidth="150" text="BACK"/>
            <Button fx:id="submitButton" prefHeight="65" prefWidth="150" text="SUBMIT"/>
            <Button fx:id="clearButton" prefHeight="65" prefWidth="150" text="CLEAR"/>
            <Button fx:id="restartButton" prefHeight="65" prefWidth="150" text="RESTART"/>
            <Button fx:id="exitButton" prefHeight="65" prefWidth="150" text="EXIT"/>
        </VBox>
    </right>

    <bottom>
        <VBox alignment="CENTER" spacing="15">
            <padding><Insets bottom="25" left="20" right="20" top="20"/></padding>
            <HBox alignment="CENTER" spacing="8">
                <Button fx:id="qButton" onAction="#handleQ" prefHeight="75" prefWidth="65" text="Q"/>
                <Button fx:id="wButton" onAction="#handleW" prefHeight="75" prefWidth="65" text="W"/>
                <Button fx:id="eButton" onAction="#handleE" prefHeight="75" prefWidth="65" text="E"/>
                <Button fx:id="rButton" onAction="#handleR" prefHeight="75" prefWidth="65" text="R"/>
                <Button fx:id="tButton" onAction="#handleT" prefHeight="75" prefWidth="65" text="T"/>
                <Button fx:id="yButton" onAction="#handleY" prefHeight="75" prefWidth="65" text="Y"/>
                <Button fx:id="uButton" onAction="#handleU" prefHeight="75" prefWidth="65" text="U"/>
                <Button fx:id="iButton" onAction="#handleI" prefHeight="75" prefWidth="65" text="I"/>
                <Button fx:id="oButton" onAction="#handleO" prefHeight="75" prefWidth="65" text="O"/>
                <Button fx:id="pButton" onAction="#handleP" prefHeight="75" prefWidth="65" text="P"/>
            </HBox>
            <HBox alignment="CENTER" spacing="8">
                <Button fx:id="aButton" onAction="#handleA" prefHeight="75" prefWidth="65" text="A"/>
                <Button fx:id="sButton" onAction="#handleS" prefHeight="75" prefWidth="65" text="S"/>
                <Button fx:id="dButton" onAction="#handleD" prefHeight="75" prefWidth="65" text="D"/>
                <Button fx:id="fButton" onAction="#handleF" prefHeight="75" prefWidth="65" text="F"/>
                <Button fx:id="gButton" onAction="#handleG" prefHeight="75" prefWidth="65" text="G"/>
                <Button fx:id="hButton" onAction="#handleH" prefHeight="75" prefWidth="65" text="H"/>
                <Button fx:id="jButton" onAction="#handleJ" prefHeight="75" prefWidth="65" text="J"/>
                <Button fx:id="kButton" onAction="#handleK" prefHeight="75" prefWidth="65" text="K"/>
                <Button fx:id="lButton" onAction="#handleL" prefHeight="75" prefWidth="65" text="L"/>
            </HBox>
            <HBox alignment="CENTER" spacing="8">
                <Button fx:id="zButton" onAction="#handleZ" prefHeight="75" prefWidth="65" text="Z"/>
                <Button fx:id="xButton" onAction="#handleX" prefHeight="75" prefWidth="65" text="X"/>
                <Button fx:id="cButton" onAction="#handleC" prefHeight="75" prefWidth="65" text="C"/>
                <Button fx:id="vButton" onAction="#handleV" prefHeight="75" prefWidth="65" text="V"/>
                <Button fx:id="bButton" onAction="#handleB" prefHeight="75" prefWidth="65" text="B"/>
                <Button fx:id="nButton" onAction="#handleN" prefHeight="75" prefWidth="65" text="N"/>
                <Button fx:id="mButton" onAction="#handleM" prefHeight="75" prefWidth="65" text="M"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>